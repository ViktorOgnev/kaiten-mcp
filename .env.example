# Choose exactly one host configuration strategy.

# Option 1: Standard Kaiten cloud
KAITEN_SUBDOMAIN=yourcompany
# KAITEN_BASE_DOMAIN=kaiten.ru

# Option 2: Custom base domain
# KAITEN_SUBDOMAIN=kaiten
# KAITEN_BASE_DOMAIN=kaiten.ru

# Option 3: Full API host override
# KAITEN_BASE_URL=https://kaiten.kaiten.ru

KAITEN_TOKEN=your-api-token

# Optional shared output/logging
# KAITEN_MCP_OUTPUT_DIR=./tmp
# LOG_LEVEL=INFO

# HTTP transport
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=8000
# MCP_HTTP_BASE_PATH=/mcp

# HTTP auth modes:
# - oauth: shared remote server with per-user Kaiten credentials collected in onboarding
# - shared: legacy single bearer token for the MCP endpoint
# - none: local/dev only
# MCP_HTTP_AUTH_MODE=oauth
# MCP_PUBLIC_URL=https://mcp.example.com/mcp
# MCP_OAUTH_ISSUER_URL=https://mcp.example.com
# MCP_RESOURCE_METADATA_URL=https://mcp.example.com/.well-known/oauth-protected-resource
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com
# MCP_REQUIRED_SCOPES=kaiten:tools

# Legacy shared HTTP auth (single-tenant only)
# MCP_AUTH_TOKEN=your-http-token
