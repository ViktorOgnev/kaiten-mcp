FROM python:3.12-slim

WORKDIR /app

# Install the package with the same pinned runtime deps and lint extras.
# Source code is still mounted at runtime, but copying it here keeps image deps in sync with pyproject.
COPY pyproject.toml .
COPY src/ src/
RUN pip install --no-cache-dir -e ".[lint]"

ENV PYTHONUNBUFFERED=1
