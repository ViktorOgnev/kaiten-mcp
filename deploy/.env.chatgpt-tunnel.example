# Copy this file to /etc/kaiten-mcp/kaiten-mcp-chatgpt.env on the server.
# The tunnel script manages MCP_PUBLIC_URL after cloudflared prints a URL.
# Do not put KAITEN_TOKEN or MCP_AUTH_TOKEN in this file.

LOG_LEVEL=INFO
MCP_HTTP_AUTH_MODE=oauth
MCP_REQUIRED_SCOPES=kaiten:tools
MCP_ALLOWED_ORIGINS=

# Managed by deploy/chatgpt-tunnel.sh.
MCP_PUBLIC_URL=https://placeholder.invalid/mcp/
MCP_OAUTH_ISSUER_URL=https://placeholder.invalid
MCP_RESOURCE_METADATA_URL=https://placeholder.invalid/.well-known/oauth-protected-resource
