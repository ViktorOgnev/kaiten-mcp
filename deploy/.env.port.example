# Copy this file to /etc/kaiten-mcp/kaiten-mcp.env on the server.
# This is a port-only smoke deployment, not the final multi-user HTTPS/OAuth mode.
# The repository is public: keep real values only in the server env file.

# Public port exposed by Docker on the server.
MCP_HTTP_PORT=8000

# Port-only smoke mode uses one shared MCP bearer token and one Kaiten API token.
MCP_HTTP_AUTH_MODE=shared
MCP_AUTH_TOKEN=replace-with-random-token

# Choose exactly one Kaiten host configuration.
KAITEN_SUBDOMAIN=yourcompany
# KAITEN_BASE_DOMAIN=kaiten.ru
# KAITEN_BASE_URL=https://kaiten.kaiten.ru

KAITEN_TOKEN=replace-with-kaiten-api-token

# Optional browser origin allowlist. Empty allows non-browser/server-side clients.
MCP_ALLOWED_ORIGINS=

LOG_LEVEL=INFO
