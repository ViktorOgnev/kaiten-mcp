# Copy this file to /etc/kaiten-mcp/kaiten-mcp.env when switching to HTTPS/OAuth.
# The repository is public: do not put Kaiten API keys or shared bearer tokens here.

# Bare public hostname. DNS A-record must point to the production server.
MCP_DOMAIN=mcp.example.com

# Browser origins allowed to call the MCP endpoint. Leave empty only for controlled testing.
MCP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com

# OAuth scope required by the MCP endpoint.
MCP_REQUIRED_SCOPES=kaiten:tools

# Runtime logging level for the Python service.
LOG_LEVEL=INFO
